{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "api/cron/daily-email.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/cron/daily-email", "dest": "/api/cron/daily-email.js" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/favicon.svg", "dest": "/public/favicon.svg" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-email",
      "schedule": "0 4 * * *"
    }
  ]
}
